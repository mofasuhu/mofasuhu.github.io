{% import '_macros.html.j2' as macros %}
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {% if not for_pdf %}
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  {% endif %}

  <title>{{ data.meta.page_title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" />
  <link rel="stylesheet" href="main.css?v={{ data.meta.css_version }}" />
  {% if for_pdf %}
  <link rel="stylesheet" href="resume_pdf.css" />
  {% endif %}
</head>
{% if not for_pdf and data.meta.google_analytics_id %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ data.meta.google_analytics_id }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ data.meta.google_analytics_id }}');
</script>
{% endif %}
<body{% if for_pdf %} class="resume-pdf"{% endif %}>
  <div class="container">
    <header class="header">
      <img src="{{ data.profile.photo }}" alt="{{ data.profile.name }}" />
      <div class="header-text">
        <h1>{{ data.profile.name }}</h1>
        <span class="headline-tag">{{ data.profile.headline }}</span>
        {% if not for_pdf %}<p class="headline-spacer"></p>{% endif %}
        <div class="contact-info">
          {% for item in data.contact %}
            {% if not item.pdf_only or for_pdf %}
            {% set link_label = item.pdf_label if for_pdf and item.pdf_label is defined else item.label %}
            <a href="{{ item.href }}" target="_blank"{% if item.aria_label %} aria-label="{{ item.aria_label }}"{% endif %}>
              <i class="{{ item.icon }}"></i>{% if link_label %} {{ link_label }}{% endif %}
            </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </header>

    <section class="section section-summary">
      <h2>{% if for_pdf %}Summary{% else %}About{% endif %}</h2>
      <p>{{ data.profile.summary }}</p>
    </section>

    <section class="section">
      <h2>Professional Experience</h2>
      {% for job in data.experience %}
        {{ macros.render_experience_block(job, for_pdf) }}
      {% endfor %}
    </section>

    {% if data.achievements %}
    <section class="section">
      <h2>Personal Achievements</h2>
      {% for achievement in data.achievements %}
        {{ macros.render_experience_block(achievement, for_pdf) }}
      {% endfor %}
    </section>
    {% endif %}

    {% if for_pdf %}
    <section class="section certifications">
      <h2>Education</h2>
      <ul>
        {% for edu in data.education %}
        <li>
          <span class="education-degree">{{ edu.degree }}</span>
          <span class="education-institution">{{ edu.institution }} | {{ edu.year }}</span>
        </li>
        {% endfor %}
      </ul>
    </section>

    <section class="section certifications">
      <h2>Certifications</h2>
      <ul class="certificates-list">
        {% for cert in data.certifications %}
        <li><span>{{ cert.name }}</span></li>
        {% endfor %}
      </ul>
    </section>

    <section class="section">
      <h2>Skills</h2>
      <div class="skill-title">Technical</div>
      <ul class="skills">
        {% for skill in data.skills.technical %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
      <div class="skill-title">Soft</div>
      <ul class="skills">
        {% for skill in data.skills.soft %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </section>
    {% else %}

    <section class="section certifications">
      <h2>Education</h2>
      <ul>
        {% for edu in data.education %}
        <li>
          <div>
            <span>{{ edu.degree }} — {{ edu.institution }} | {{ edu.year }}</span>
            {% if edu.certificate %}
            <button type="button" onclick="showModal('{{ edu.certificate.modal_id }}')">View certificate</button>
            {% endif %}
          </div>
        </li>
        {% endfor %}
      </ul>
      {% for edu in data.education %}
        {% if edu.certificate %}
        <div id="{{ edu.certificate.modal_id }}" class="modal">
          <div class="{{ edu.certificate.modal_class }}">
            <span class="close" onclick="closeModal('{{ edu.certificate.modal_id }}')">&#xD7;</span>
            <img src="{{ edu.certificate.image }}" alt="{{ edu.certificate.alt }}" style="width:100%" />
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </section>

    <section class="section certifications">
      <h2>Certifications &amp; Courses</h2>
      <ul class="certificates-list">
        {% for cert in data.certifications %}
        <li>
          <div>
            <span>{{ cert.name }}</span>
            <button type="button" onclick="showModal('{{ cert.modal_id }}')">View certificate</button>
          </div>
        </li>
        {% endfor %}
      </ul>
    </section>

    {% for cert in data.certifications %}
    <div id="{{ cert.modal_id }}" class="modal">
      <div class="{{ cert.modal_class }}">
        <span class="close" onclick="closeModal('{{ cert.modal_id }}')">&#xD7;</span>
        <img src="{{ cert.image }}" alt="{{ cert.alt }}" style="width:100%" />
      </div>
    </div>
    {% endfor %}

    <section class="section">
      <h2>Skills</h2>
      <div class="skill-title">Technical</div>
      <ul class="skills">
        {% for skill in data.skills.technical %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
      <div class="skill-title">Soft skills</div>
      <ul class="skills">
        {% for skill in data.skills.soft %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if for_pdf and data.pdf %}
    <section class="section pdf-references">
      <h2>{{ data.pdf.references_heading }}</h2>
      <p class="pdf-references-line">
        {{ data.pdf.references_text }}
        <a href="{{ data.pdf.certificates_url }}" class="pdf-certificates-link" target="_blank"
          title="View certificates on Google Drive" aria-label="View certificates">
          <i class="{{ data.pdf.certificates_icon }}"></i>
        </a>
      </p>
    </section>
    {% endif %}
  </div>

  {% if not for_pdf %}
  <script src="script.js?v={{ data.meta.script_version }}"></script>
  {% endif %}
</body>

</html>
